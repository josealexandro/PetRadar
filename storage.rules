rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de animais: usuário autenticado só grava na própria pasta; leitura pública.
    match /animals/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
